# ─── Railway / Render Environment Variables ──────────────────────────────────
# Set these in your Railway project → Variables tab
# (do NOT commit actual values)

APP_ENV=production
FREE_CHAPTER_LIMIT=3

# Your Vercel frontend URL — used for CORS allow-list
FRONTEND_URL=https://your-app.vercel.app

# Anthropic API — required for Phase 2 adaptive & assessment features
ANTHROPIC_API_KEY=sk-ant-...

# Cloudflare R2 — replaces local JSON files in production
# https://dash.cloudflare.com → R2 → your bucket → Manage R2 API tokens
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=course-companion-content
R2_ENDPOINT_URL=https://<R2_ACCOUNT_ID>.r2.cloudflarestorage.com
