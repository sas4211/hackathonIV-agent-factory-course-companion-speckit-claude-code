# ─── Vercel Environment Variables ────────────────────────────────────────────
# Set these in: Vercel Dashboard → Project → Settings → Environment Variables
# Scope: Production (and Preview if needed)

# FastAPI backend URL (your Railway / Render deployment)
BACKEND_URL=https://your-backend.up.railway.app

# Clerk Authentication — use LIVE keys for production
# https://dashboard.clerk.com → Your App → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_...
CLERK_SECRET_KEY=sk_live_...

# Clerk redirect URLs (no changes needed)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/
