# Backend API URL
# Leave unset to use the Next.js /api proxy (recommended for production)
# Set to http://localhost:8000 to bypass the proxy in local development
# NEXT_PUBLIC_API_URL=http://localhost:8000

# Clerk Authentication Keys
# Get these from https://dashboard.clerk.com → Your App → API Keys
# Leave both unset to run in demo mode (no real auth)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your_publishable_key_here
CLERK_SECRET_KEY=sk_test_your_secret_key_here

# Clerk redirect URLs (optional — these defaults work for local dev)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/
