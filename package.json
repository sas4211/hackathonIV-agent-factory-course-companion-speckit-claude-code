{
  "name": "course-companion-root",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "dev": "concurrently \"npm:dev:backend\" \"npm:dev:frontend\"",
    "dev:backend": "cd packages/backend && uvicorn main:app --reload --port 8000",
    "dev:frontend": "cd packages/web && next dev",
    "vercel-build": "npm run build --workspace=packages/web"
  },
  "workspaces": [
    "packages/*"
  ],
  "dependencies": {
    "next": "^15.3.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}